# slideless — .gitignore
# Esta skill nao tem build/deps Node; o template generico foi substituido
# por entries especificas ao workflow real (Python scripts, geracoes locais,
# configs de IDE, backups).

# ─── Sistema operacional ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~

# ─── IDEs e editores ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ─── Claude Code local (configs por maquina, nao do repo) ─────────────
# .claude/ contem agents customizados, configs locais. Cada dev pode ter o
# seu — nao versionar. O CLAUDE.md raiz do repo permanece versionado.
.claude/
claude.local.md

# ─── Python (scripts/) ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# ─── Playwright (scripts/exportar_pdf.py) ─────────────────────────────
.cache/ms-playwright/

# ─── Backups e temporarios das skill commands ─────────────────────────
*-old.html
*-old.md
*.bak
*.tmp
*.log

# ─── Saidas de geracao local nao publicaveis ──────────────────────────
# /demos/ contem demos REAIS commitadas; sandboxes locais ficam em /sandbox/
sandbox/
output/
outputs/
*.tmp.html

# ─── PDFs/screenshots gerados via /exportar-* (regeneraveis) ──────────
*.pdf
demos/*/screenshots/

# ─── Segredos ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# ─── Histerese de Node.js (caso alguem adicione mais tarde) ──────────
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
